---
# ============================================================================
# clang-tidy configuration
# ============================================================================
#
# Naming conventions:
#   Classes/Structs/Types:      CamelCase            (MyClass)
#   Functions/Methods:          camelBack            (myFunction)
#   Local variables/params:     lower_case           (my_variable)
#   Class member variables:     lower_case           (m_my_member)
#   Struct/public members:      lower_case           (my_member)
#   Global/static constants:    lower_case           (g_my_constant)
#   Classic enum values:        UPPER_CASE           (MY_VALUE)
#   Scoped enum class values:   CamelCase            (MyValue)
#   Namespaces:                 lower_case           (my_namespace)
#   Macros:                     UPPER_CASE           (MY_MACRO)
#
# ============================================================================

# Two cppcoreguidelines checks are disabled as deliberate project style (comments cannot live
# inside the YAML folded scalar below): avoid-const-or-ref-data-members conflicts with the
# codebase's non-owning reference-member ports (controller Impl, edit contexts, view AudioPorts),
# and non-private-member-variables-in-classes conflicts with the documented public-field value
# structs (error types, view state, edits); see docs/design/coding-conventions.md.
Checks: >
  -*,
  bugprone-*,
  -bugprone-easily-swappable-parameters,
  modernize-*,
  -modernize-use-trailing-return-type,
  performance-*,
  misc-const-correctness,
  readability-braces-around-statements,
  readability-identifier-naming,
  cppcoreguidelines-*,
  -cppcoreguidelines-avoid-magic-numbers,
  -cppcoreguidelines-avoid-const-or-ref-data-members,
  -cppcoreguidelines-non-private-member-variables-in-classes,
  -cppcoreguidelines-pro-bounds-pointer-arithmetic,
  -cppcoreguidelines-pro-bounds-avoid-unchecked-container-access,

WarningsAsErrors: '*'

# Catch2's TEST_CASE machinery expands __COUNTER__, which clang 22's pedantic pass flags as a
# C2y extension; the compile flags carry -Werror, promoting it to a hard parse error that no
# Checks entry can filter, so it must be disabled at the parse level. None of the product
# compilers warn on it.
ExtraArgs: ['-Wno-c2y-extensions']

# clang-tidy parses HeaderFilterRegex with llvm::Regex, which does not support negative
# lookahead. Keep this as a positive match over project-owned paths rather than trying to
# exclude external/ with a pattern like ^(?!.*[\\/]external[\\/]).*.
HeaderFilterRegex: '.*[\\/]rock-hero-(common|editor|game)[\\/].*'

# Exclude third-party and generated headers explicitly when the current clang-tidy version
# supports ExcludeHeaderFilterRegex. This keeps generated files such as BinaryData.h and
# anything under external/ or build/ out of header diagnostics.
ExcludeHeaderFilterRegex: '.*[\\/](external|build)[\\/].*'

CheckOptions:
  - key: readability-braces-around-statements.ShortStatementLines
    value: '0'

  # The do { } while (0) statement wrapper inside the sanctioned RH_LOG_* macros is the standard
  # way to make a multi-statement macro behave as one statement; only flag hand-written do-while.
  - key: cppcoreguidelines-avoid-do-while.IgnoreMacros
    value: 'true'

  # The codebase marks a deliberately discarded result with an explicit static_cast<void>(...)
  # (best-effort teardown, and startup/retry route application whose failure is handled in-band
  # through a staged prompt). Honor that idiom so an explicit void cast satisfies the check, while
  # a bare unchecked call that returns a status/expected still fails.
  - key: bugprone-unused-return-value.AllowCastToVoid
    value: 'true'

  # Allocation failure (OOM) is not a recoverable exception in this app: a function that can only
  # throw via an allocation is allowed to be noexcept (message-loop async callbacks, best-effort
  # cleanup destructors, and status accessors that copy a std::string/path all fall here). A
  # function that can throw a logic exception is still flagged.
  - key: bugprone-exception-escape.IgnoredExceptions
    value: 'bad_alloc,bad_array_new_length,length_error'

  # --------------------------------------------------------------------------
  # Const correctness
  # --------------------------------------------------------------------------
  - key: misc-const-correctness.AnalyzeValues
    value: 'true'
  - key: misc-const-correctness.AnalyzeReferences
    value: 'true'
  - key: misc-const-correctness.AnalyzePointers
    value: 'true'
  - key: misc-const-correctness.WarnPointersAsValues
    value: 'false'
  - key: misc-const-correctness.TransformPointersAsValues
    value: 'false'
  - key: misc-const-correctness.WarnPointersAsPointers
    value: 'true'
  - key: misc-const-correctness.TransformPointersAsPointers
    value: 'true'

  # --------------------------------------------------------------------------
  # Types
  # --------------------------------------------------------------------------
  - key: readability-identifier-naming.ClassCase
    value: CamelCase
  - key: readability-identifier-naming.AbstractClassCase
    value: CamelCase
  - key: readability-identifier-naming.StructCase
    value: CamelCase
  - key: readability-identifier-naming.UnionCase
    value: CamelCase
  - key: readability-identifier-naming.EnumCase
    value: CamelCase
  - key: readability-identifier-naming.TypeAliasCase
    value: CamelCase
  - key: readability-identifier-naming.TypedefCase
    value: CamelCase
  - key: readability-identifier-naming.ConceptCase
    value: CamelCase

  # --------------------------------------------------------------------------
  # Functions & Methods
  # --------------------------------------------------------------------------
  - key: readability-identifier-naming.FunctionCase
    value: camelBack
  - key: readability-identifier-naming.GlobalFunctionCase
    value: camelBack
  - key: readability-identifier-naming.MethodCase
    value: camelBack
  - key: readability-identifier-naming.ClassMethodCase
    value: camelBack
  - key: readability-identifier-naming.PrivateMethodCase
    value: camelBack
  - key: readability-identifier-naming.ProtectedMethodCase
    value: camelBack
  - key: readability-identifier-naming.PublicMethodCase
    value: camelBack
  - key: readability-identifier-naming.VirtualMethodCase
    value: camelBack
  - key: readability-identifier-naming.ConstexprFunctionCase
    value: camelBack
  - key: readability-identifier-naming.ConstexprMethodCase
    value: camelBack

  # --------------------------------------------------------------------------
  # Local Variables & Parameters
  # --------------------------------------------------------------------------
  - key: readability-identifier-naming.VariableCase
    value: lower_case
  - key: readability-identifier-naming.LocalVariableCase
    value: lower_case
  - key: readability-identifier-naming.LocalConstantCase
    value: lower_case
  - key: readability-identifier-naming.LocalConstantPointerCase
    value: lower_case
  - key: readability-identifier-naming.LocalPointerCase
    value: lower_case
  - key: readability-identifier-naming.ParameterCase
    value: lower_case
  - key: readability-identifier-naming.ConstantParameterCase
    value: lower_case
  - key: readability-identifier-naming.ConstantPointerParameterCase
    value: lower_case
  - key: readability-identifier-naming.PointerParameterCase
    value: lower_case
  - key: readability-identifier-naming.ParameterPackCase
    value: lower_case

  # --------------------------------------------------------------------------
  # Member Variables (m_ prefix for private/protected, no prefix for public;
  # ClassMember covers static data members, which take s_ instead of m_)
  # --------------------------------------------------------------------------
  - key: readability-identifier-naming.MemberCase
    value: lower_case
  - key: readability-identifier-naming.MemberPrefix
    value: ''
  - key: readability-identifier-naming.ClassMemberCase
    value: lower_case
  - key: readability-identifier-naming.ClassMemberPrefix
    value: s_
  - key: readability-identifier-naming.PrivateMemberCase
    value: lower_case
  - key: readability-identifier-naming.PrivateMemberPrefix
    value: m_
  - key: readability-identifier-naming.ProtectedMemberCase
    value: lower_case
  - key: readability-identifier-naming.ProtectedMemberPrefix
    value: m_
  - key: readability-identifier-naming.PublicMemberCase
    value: lower_case
  - key: readability-identifier-naming.PublicMemberPrefix
    value: ''
  - key: readability-identifier-naming.ConstantMemberCase
    value: lower_case
  - key: readability-identifier-naming.ConstantMemberPrefix
    value: ''

  # --------------------------------------------------------------------------
  # Global / Static Constants (g_ prefix, lower_case)
  # --------------------------------------------------------------------------
  - key: readability-identifier-naming.GlobalConstantCase
    value: lower_case
  - key: readability-identifier-naming.GlobalConstantPrefix
    value: g_
  - key: readability-identifier-naming.GlobalConstantPointerCase
    value: lower_case
  - key: readability-identifier-naming.GlobalConstantPointerPrefix
    value: g_
  - key: readability-identifier-naming.StaticConstantCase
    value: lower_case
  - key: readability-identifier-naming.StaticConstantPrefix
    value: g_
  - key: readability-identifier-naming.ClassConstantCase
    value: lower_case
  - key: readability-identifier-naming.ClassConstantPrefix
    value: g_

  # --------------------------------------------------------------------------
  # Global Variables (non-const)
  # --------------------------------------------------------------------------
  - key: readability-identifier-naming.GlobalVariableCase
    value: lower_case
  - key: readability-identifier-naming.GlobalVariablePrefix
    value: g_
  - key: readability-identifier-naming.GlobalPointerCase
    value: lower_case
  - key: readability-identifier-naming.GlobalPointerPrefix
    value: g_
  - key: readability-identifier-naming.StaticVariableCase
    value: lower_case
  - key: readability-identifier-naming.StaticVariablePrefix
    value: g_

  # --------------------------------------------------------------------------
  # Enum Values
  # --------------------------------------------------------------------------
  - key: readability-identifier-naming.EnumConstantCase
    value: UPPER_CASE
  - key: readability-identifier-naming.ScopedEnumConstantCase
    value: CamelCase

  # --------------------------------------------------------------------------
  # Namespaces
  # --------------------------------------------------------------------------
  - key: readability-identifier-naming.NamespaceCase
    value: lower_case
  - key: readability-identifier-naming.InlineNamespaceCase
    value: lower_case

  # --------------------------------------------------------------------------
  # Template Parameters
  # --------------------------------------------------------------------------
  - key: readability-identifier-naming.TemplateParameterCase
    value: CamelCase
  - key: readability-identifier-naming.TypeTemplateParameterCase
    value: CamelCase
  - key: readability-identifier-naming.TemplateTemplateParameterCase
    value: CamelCase
  - key: readability-identifier-naming.ValueTemplateParameterCase
    value: CamelCase

  # --------------------------------------------------------------------------
  # Macros
  # --------------------------------------------------------------------------
  - key: readability-identifier-naming.MacroDefinitionCase
    value: UPPER_CASE

  # Logging is the sanctioned exception to "no function-like macros": the RH_LOG_* and RH_RT_LOG_*
  # facades must be macros to preserve source location, skip disabled-level argument evaluation,
  # and allow compile-time stripping. RH_DETAIL_ covers the facade's internal helper layer (the
  # shared body plus the expansion shim MSVC's traditional preprocessor needs to forward
  # __VA_ARGS__). Allow those prefixes alongside the default DEBUG_ allowance.
  - key: cppcoreguidelines-macro-usage.AllowedRegexp
    value: '^(DEBUG_|RH(_RT)?_LOG_|RH_DETAIL_)'

  # --------------------------------------------------------------------------
  # Ignore Qt-generated files and common Qt patterns
  # --------------------------------------------------------------------------
  - key: readability-identifier-naming.ClassIgnoredRegexp
    value: '^Q[A-Z].*'
  # Tracktion's plugin contract requires the exact static member name xmlTypeName; the
  # framework looks plugins up by it, so the project naming convention exempts it.
  # quill::FrontendOptions requires these exact static member names as its
  # customization contract, like Tracktion's xmlTypeName below.
  - key: readability-identifier-naming.ClassConstantIgnoredRegexp
    value: '^(xmlTypeName|queue_type|initial_queue_capacity|blocking_queue_retry_interval_ns|unbounded_queue_max_capacity|huge_pages_policy)$'
  - key: readability-identifier-naming.ClassMemberIgnoredRegexp
    value: '^xmlTypeName$'
  - key: readability-identifier-naming.MethodIgnoredRegexp
    value: '^(qt_|_q_|on[A-Z]).*'
...
